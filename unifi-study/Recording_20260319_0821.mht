<script type="text/javascript">
function zoomToggle(num)
{
  var img = document.getElementById("ss-" + num);
  
  if (img.className == "screenshot") {
    img.className = "screenshot-thumb";
  }
  else {
    img.className = "screenshot";
  }
  
  return false;
}

function AddComment(index)
{
    // Hide user's previous comment, "Add Comment" and "Update Comment" buttons.
    document.getElementById("AddCommentButtonId" + index).style.display = 'none';
    document.getElementById("UpdateCommentButtonId" + index).style.display = 'none';
    document.getElementById("CommentTextId" + index).style.display = 'none';

    // Empty text input box.
    document.getElementById("CommentInputText" + index).value = '';

    // Display text input box, OK and Cancel buttons.
    document.getElementById("CommentInputEntityItemId" + index).style.display = 'inline';
}

function AddCommentA11yFixes(index)
{
    // Please note this function is only for MomentFeature_StepsRecorderA11yFixes_v01.
    // Hide user's previous comment, "Add Comment" and "Update Comment" buttons.
    document.getElementById("AddCommentButtonId" + index).style.display = 'none';
    document.getElementById("UpdateCommentButtonId" + index).style.display = 'none';
    document.getElementById("CommentTextId" + index).style.display = 'none';

    // Empty text input box.
    document.getElementById("CommentInputText" + index).value = '';

    // Display text input box, OK and Cancel buttons.
    document.getElementById("CommentInputEntityItemId" + index).style.display = 'inline';

    // Set focus on text input box.
    document.getElementById("CommentInputText" + index).focus();
}

function AddCommentOK(index)
{
    // Display user's comment.
    document.getElementById("CommentTextId" + index).style.display = 'inline';
    document.getElementById("CommentTextId" + index).innerText = document.getElementById("CommentInputText" + index).value;

    // Display "Add Comment" or "Update Comment" button.
    if (document.getElementById("CommentTextId" + index).innerText)
    {
        document.getElementById("UpdateCommentButtonId" + index).style.display = 'inline';
    }
    else
    {
        document.getElementById("AddCommentButtonId" + index).style.display = 'inline';
    }

    // Hide text input box, OK and Cancel buttons.
    document.getElementById("CommentInputEntityItemId" + index).style.display = 'none';
}

function AddCommentCancel(index)
{
    // Hide text input box, OK and Cancel buttons.
    document.getElementById("CommentInputEntityItemId" + index).style.display = 'none';

    // Display user's previous comment if there is one.
    document.getElementById("CommentTextId" + index).style.display = 'inline';

    // Display "Add Comment" or "Update Comment" button.
    if (document.getElementById("CommentTextId" + index).innerText)
    {
        document.getElementById("UpdateCommentButtonId" + index).style.display = 'inline';
    }
    else
    {
        document.getElementById("AddCommentButtonId" + index).style.display = 'inline';
    }
}

</script>
